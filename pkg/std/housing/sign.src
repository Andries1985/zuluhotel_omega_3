							0xA42A: CreateItemInBackpack( who, 0x6141, 1 ); // customhouse58
							0xA42B: CreateItemInBackpack( who, 0x6142, 1 ); // customhouse59
							0xA42C: CreateItemInBackpack( who, 0x6143, 1 ); // customhouse60
							0xA42D: CreateItemInBackpack( who, 0x6144, 1 ); // customhouse61
							0xA42E: CreateItemInBackpack( who, 0x6145, 1 ); // customhouse62
							0xA42F: CreateItemInBackpack( who, 0x6148, 1 ); // customhouse63
							0xA430: CreateItemInBackpack( who, 0x614E, 1 ); // customhouse64
							0xA431: CreateItemInBackpack( who, 0x614F, 1 ); // customhouse65
