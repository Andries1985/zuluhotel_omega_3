use uo;

include "include/random";
include "include/attributes";
include "include/dotempmods";

Program walkOn(mobile)
	if(GetObjProperty(mobile, "iChampSpawn"))
		if(!GetObjProperty(mobile, "AlreadyPorted"))
			SetObjProperty(mobile, "AlreadyPorted", 1);
			var rtime := Random(5)+5;
			Sleep(rtime);
			MoveObjectToLocation(mobile, DEFAULT_LOCATION_ITEM_CREATION_X, DEFAULT_LOCATION_ITEM_CREATION_Y, DEFAULT_LOCATION_ITEM_CREATION_Z, DEFAULT_LOCATION_ITEM_CREATION_R, MOVEOBJECT_FORCELOCATION);
			SetHP(mobile, GetMaxHP(mobile));
			CurePoison(mobile);
			EraseObjProperty(mobile, "AlreadyPorted");
		endif
	endif
endprogram