// Synopsis: Raise the chosen skill caps for all characters
use uo;

include "include/attributes";
include ":gumps:include/gumps";
include "include/itemutil";
include ":staff:include/staff";

const SKILL_CHECKBOX_OFFSET := 1000;

Program tss( who ) 

	var mobile := target(who);
	if (!mobile)
		SendSysMessage(who, "Canceled", FONT_NORMAL, 43);
		return 0;
	endif
	
	if(!GetObjProperty(mobile, "pScrollMatrix"))
		var newMatrix := {}, i;
		for(i:=0; i<49; i:=i+1)
			newMatrix.append(0);
		endfor
		SetObjProperty(mobile, "pScrollMatrix", newMatrix);
	endif

	var matrix := GetObjProperty(mobile, "pScrollMatrix");
	var gump := GFCreateGump(20, 20, 2, 560);

	// The main gump screen
	GFResizePic(gump, 20, 20, 9250,720, 560);
	GFResizePic(gump, 30, 30, 9350, 700, 540);
	GFResizePic(gump, 260, 20, 9250,240, 40);
	GFResizePic(gump, 270, 30, 9350, 220, 20);
	GFTextLine(gump, 300, 30, 43, "Raise Multiple Skill Caps");
	var y := 70;
	var line := 17;
	var i := 0;
	var x := 100;
	var name;
	var colour := 999;
	var count := 1;
	var skill;
	repeat
	if(count != 49)
		name := GetAttributeIdBySkillId( count );
		skill := GetSkillIdByAttributeId( name );
		skill := CDbl(GetBaseSkillBaseValue( mobile, skill )/10.0);
	endif
	if (count == 49)
		name := ATTRIBUTEID_ALCHEMY;
		skill := CDbl(GetBaseSkillBaseValue( mobile, SKILLID_ALCHEMY )/10.0);
	endif

	if (i >= line)
		x := x + 230;
		i := 0;
		y := 70;
	endif

	colour := 67;
	GFCheckBox(gump, x-40, y, 9026, 9027, 0, count + SKILL_CHECKBOX_OFFSET);

	GFTextLine(gump, x, y, colour, 130+matrix[count]);
	GFTextLine(gump, x+45, y, colour, name);
	y := y + 26;
	i := i + 1;
	count := count + 1;
	until (count >= SKILLID_MAX+1);

	GFResizePic(gump, 470, 450, 9350, 260, 120);
	GFTextLine(gump, 485, 458, 43, "Select skills, then choose raise amount:");
	GFAddButton(gump, 485, 488, 2117, 2118, 1, 5005);
	GFTextLine(gump, 510, 490, 67, "+5");
	GFAddButton(gump, 535, 488, 2117, 2118, 1, 5010);
	GFTextLine(gump, 560, 490, 67, "+10");
	GFAddButton(gump, 595, 488, 2117, 2118, 1, 5015);
	GFTextLine(gump, 620, 490, 67, "+15");
	GFAddButton(gump, 655, 488, 2117, 2118, 1, 5020);
	GFTextLine(gump, 680, 490, 67, "+20");
	GFTextLine(gump, 485, 518, 67, "Unchecked skills are not changed.");

	var result := GFSendGump(who, gump);
	if(result[0] == 0)
		SendSysMessage(who, "Cancelled.");
		return;
	endif

	var amount := GetRaiseAmount(result[0]);
	if(!amount)
		SendSysMessage(who, "Choose +5, +10, +15 or +20.");
		return;
	endif

	var selected_count := 0;
	var key;
	foreach key in (result.keys)
		if(key > SKILL_CHECKBOX_OFFSET and key <= SKILL_CHECKBOX_OFFSET + SKILLID_MAX)
			var skill_id := key - SKILL_CHECKBOX_OFFSET;
			matrix[skill_id] := matrix[skill_id] + amount;
			if(matrix[skill_id] > 20)
				matrix[skill_id] := 20;
			endif
			selected_count := selected_count + 1;
		endif
	endforeach

	if(selected_count == 0)
		SendSysMessage(who, "No skills were selected.");
		return;
	endif

	SetObjProperty(mobile, "pScrollMatrix", matrix);
	LogCommand(who, GetProcess(GetPid()).name, mobile.name+"/"+mobile.serial, "Raised "+selected_count+" skill cap(s) by "+amount);
	SendSysMessage(who, "Raised " + selected_count + " skill cap(s) by " + amount + ". Type .showcaps to verify.");
	PlayObjectCenteredEffectEx(mobile, 0x33EA, 0x1, 10);
	PlayObjectCenteredEffectEx(mobile, 0x373A, 0x1, 10);
	PlaySoundEffect(mobile, 0x5C1);


endprogram

function GetRaiseAmount(button_id)
	case(button_id)
		5005:	return 5;
		5010:	return 10;
		5015:	return 15;
		5020:	return 20;
		default:	return 0;
	endcase
endfunction