use uo;
use polsys;

program makesilver(mobile, amount)

	if(!amount)
		SendSysMessage(mobile, "Useage: .makesilver [amount]");
		return;
	endif

	amount := CInt(amount);

	SendSysMessage(mobile, "Target the container to hold the silver");
	var cont := Target(mobile);

	if(!cont)
		SendSysMessage(mobile, "Cancelled");
		return;
	endif

	//if(!cont.IsContainer())
	if (!cont.isa(POLCLASS_CONTAINER))
		SendSysMessage(mobile, "That is not a container");
		return;
	endif

	var orgamount := amount;
	var created := 0;
	var stacks := 0;
	while(amount > 60000)
		if(CreateItemInContainer(cont, "silvercoin", 60000))
			amount := amount - 60000;
			created := created + 60000;
			stacks := stacks + 1;
		else
			SendSysMessage(mobile, "The container is full!");
			SendSysMessage(mobile, "Created "+CStr(created)+", remaining: "+CStr(orgamount-created));
			return;
		endif
	endwhile

	if(amount > 0)
		if(CreateItemInContainer(cont, "silverCoin", amount))
			created := created + amount;
		else
			SendSysMessage(mobile, "The container is full!");
			SendSysMessage(mobile, "Created "+CStr(created)+", remaining: "+CStr(orgamount-created));
		endif
	endif

	SendSysMessage(mobile, "Done. Made "+CStr(stacks)+" stacks");

endprogram