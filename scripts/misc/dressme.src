function DressPoor(me,gender)

	var theitem;

	var item := 0;
	case (Random(5))
	0:	item := 0x0f64;//Torch
	1:	item := 0x0A0F;//candle
	endcase
	
	if (item)
		theitem := CreateItemAtLocation( DEFAULT_LOCATION_ITEM_CREATION_X, DEFAULT_LOCATION_ITEM_CREATION_Y, DEFAULT_LOCATION_ITEM_CREATION_Z, item, 1, DEFAULT_LOCATION_ITEM_CREATION_R );
		theitem.facing := 1;
		if( theitem.graphic == 0x0f64 )
			theitem.graphic := 0xa12;
		endif
		EquipItem(me,theitem);
	endif

	item := 0;
	case (Random(5))
	0:	item := 0x170D;//Sandals
	1:	item := 0x170D;//Sandals
	2:	item := 0x170F;//Shoes
	3:	item := 0x170F;//Shoes
	endcase

	CreateAndEquip(me,item,makeclothcolor());

	item := 0;
	if (!gender)
		case (Random(3))
			0:	item := 0x153A;		//LongPants
			1:	item := 0x152E;		//Short Pants
			2:	item := 0x152E;		//Short Pants
		endcase
		CreateAndEquip(me,item,makeclothcolor());

		case (Random(3))
			0:	item := 0x1517;		//Shirt
			1:	item := 0x1517;		//Shirt
			2:	item := 0x1F7B;		//Doublet
		endcase
		CreateAndEquip(me,item,makeclothcolor());
	else
		case (Random(2))
		0:
			//shirt and skirt or kilt
			CreateAndEquip(me,0x1517,makeclothcolor());
			if (Random(2))
				item := 0x1537;
			else
				item := 0x1516;
			endif
			CreateAndEquip(me,item,makeclothcolor());
		1:
			//plaindress
			CreateAndEquip(me,0x1F01,makeclothcolor());
		endcase
	endif

	item := 0;
	case (Random(6))
		0:	item := 0x153B;//apron
		1:	item := 0x153D;//fullapron
	endcase

	CreateAndEquip(me,item,makeclothcolor());

	item := 0;
	case (Random(6))
		0:	item := 0x153F;		//Bandana
		1:	item := 0x1543;		//Skullcap
		2:	item := 0x1713;		//Floppy Hat
	endcase

	CreateAndEquip(me,item,makeclothcolor());

endfunction

function DressRich(me,gender)

	var theitem;

	var item := 0;
	case (Random(5))
	1:	item := 0x0A0F;//candle
	2:	item := 0x0A15;//lantern
	endcase
	
	if (item)
		theitem := CreateItemAtLocation( DEFAULT_LOCATION_ITEM_CREATION_X, DEFAULT_LOCATION_ITEM_CREATION_Y, DEFAULT_LOCATION_ITEM_CREATION_Z, item, 1, DEFAULT_LOCATION_ITEM_CREATION_R );
		theitem.facing := 1;
		EquipItem(me,theitem);
	endif

	item := 0;
	case (Random(3))
		0:	item := 0x170F;//Shoes
		1:	item := 0x170B;//LeatherBoots
		2:	item := 0x1711;//Thighboots
	endcase
	CreateAndEquip(me,item,makeclothcolor());

	item := 0;
	if (!gender)
		//longpants
		CreateAndEquip(me,0x153A,makeclothcolor());

		//fancy shirt
		CreateAndEquip(me,0x1EFD,makeclothcolor());

		item := 0;
		case (Random(6))
			0:	item := 0x1F7B;		//Doublet
			1:	item := 0x1FA1;		//Tunic
			2:	item := 0x1FFD;		//Surcoat
			3:	item := 0x1541;		//Body Sash
		endcase
		CreateAndEquip(me,item,makeclothcolor());
	else
		case (Random(2))
		0:
			//plaindress
			CreateAndEquip(me,0x1F01,makeclothcolor());
		1:
			//fancydress
			CreateAndEquip(me,0x1EFF,makeclothcolor());
		endcase

		if (Random(4)==1)
			//fancy shirt
			CreateAndEquip(me,0x1EFD,makeclothcolor());
		endif
	endif

	if (Random(3)==1)
		CreateAndEquip(me,0x1515,makeclothcolor());
	endif

	item := 0;
	case (Random(6))
		0:	item := 0x1713;		//Floppy Hat
		1:	item := 0x1715;		//Cap
		2:	item := 0x1719;		//Bonnet
		3:	item := 0x171A;		//Feathered Hat
	endcase
	CreateAndEquip(me,item,makeclothcolor());

endfunction

