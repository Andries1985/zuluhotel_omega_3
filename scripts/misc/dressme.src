use os;
use uo;
use npc;

include "include/attributes";
include "include/client";
include "include/random";
include "include/constants/locations";

program Dress (parms)

	set_critical(0);

	var me := parms[1];
	var text := lower(parms[2]);

	var beard := GetEquipmentByLayer( me, LAYER_BEARD );
	DestroyItem( beard );
	var hair := GetEquipmentByLayer( me, LAYER_HAIR );
	DestroyItem( hair );
	foreach thing in listequippeditems(me)
		if (thing.objtype != 0x0E75)
			if (me.backpack)
				MoveItemToContainer(thing, me.backpack);
			else
			    DestroyItem(thing);
			endif
		endif
	endforeach

	var gender := me.gender;

	PlaceHair(me, gender);

	if (text=="poor")
		DressPoor(me,gender);
		return;
	elseif (text=="rich")
		DressRich(me,gender);
		return;
	elseif (text=="warrior")
		DressWar(me,gender);
		return;
	elseif (text=="weakwarrior")
		DressLeather(me,gender);
		return;
	elseif (text=="mage")
		DressMage(me,gender);
		return;
	endif

endprogram

function CreateAndEquip(me,item,color)

	if (item)
		var theitem := CreateItemAtLocation( DEFAULT_LOCATION_ITEM_CREATION_X , DEFAULT_LOCATION_ITEM_CREATION_Y, DEFAULT_LOCATION_ITEM_CREATION_Z, item, 1, DEFAULT_LOCATION_ITEM_CREATION_R );
		if (theitem)
			if (EquipItem(me,theitem))
				theitem.color := color;
				SetObjProperty(theitem, "noloot", 1);
			else
				DestroyItem(theitem);
			endif
		endif
	endif

endfunction

function PlaceHair(me,gender)

	var haircolor := MakeHairColor();
	var hair := 0;
	if (!gender)
		PlaceBeard(me, haircolor);
		case (Random(11))
			0:	Hair := 0x203b;
			1:	Hair := 0x203b;
			2:	Hair := 0x203C;
			3:	Hair := 0x203d;
			4:	Hair := 0x2044;
			5:	Hair := 0x2045;
			6:	Hair := 0x2047;
			7:	Hair := 0x2048;
			8:	Hair := 0x204a;
			9:	Hair := 0x203b;
			10:	Hair := 0;
		endcase
	else
		case (Random(10))
			0:	Hair := 0x203b;
			1:	Hair := 0x203C;
			2:	Hair := 0x203C;
			3:	Hair := 0x203d;
			4:	Hair := 0x2045;
			5:	Hair := 0x2046;
			6:	Hair := 0x2047;
			7:	Hair := 0x2049;
			8:	Hair := 0x204a;
			9:	Hair := 0x203C;
		endcase
	endif

	var thehair;
	CreateAndEquip(me,hair,haircolor);

endfunction

function PlaceBeard(me,haircolor)

	var hair;
	var Beard := 0;
	case (Random(18))
	0:	Beard := 0x203e;//longbeard
	1:	Beard := 0x203f;//shorbeard
	2:	Beard := 0x2040;//goatee
	3:	Beard := 0x2041;//mustache
	4:	Beard := 0x204b;//shortbeardnstache
	5:	Beard := 0x204c;//longbeardnstache
	6:	Beard := 0x204d;//vandyke
	7:	Beard := 0x2041;//mustache
	8:	Beard := 0x204b;//shortbeardnstache
	9:	Beard := 0x204d;//vandyke
	endcase

	CreateAndEquip(me,Beard,haircolor);
		
endfunction

function MakeHairColor()

	//return Random(46)+1102;
	return Random(3000);

endfunction

