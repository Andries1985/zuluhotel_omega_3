		19: hidecolor := 1165;
		20: hidecolor := 1154;
		21: hidecolor := 1281;
		22: hidecolor := 0;
	endcase

	case (Random(2))
		0:	item := 0x170B;		//LeatherBoots
		1:	item := 0x1711;		//ThighBoots
	endcase
	CreateAndEquip(me,item,CInt(hidecolor));

	//leather
	item := 0x13C7;		//LeatherGorget
	CreateAndEquip(me,item,CInt(hidecolor));
	item := 0x13C5;		//LeatherSleeves
	CreateAndEquip(me,item,CInt(hidecolor));
	item := 0x13C6;		//LeatherGloves
	CreateAndEquip(me,item,CInt(hidecolor));
	if (Random(4)==1)
		item := 0x1DB9;		//LeatherCap
		CreateAndEquip(me,item,CInt(hidecolor));
	endif

	if (!gender)
		item := 0x13CB;		//LeatherLeggings
		CreateAndEquip(me,item,CInt(hidecolor));
		item := 0x13CC;		//LeatherTunic
		CreateAndEquip(me,item,CInt(hidecolor));
	else
		case (Random(2))
		0:
			item := 0x13CB;		//LeatherLeggings
		1:
			item := 0x1C08;		//LeatherSkirt
		endcase
		CreateAndEquip(me,item,CInt(hidecolor));

		case (Random(2))
		0:
			item := 0x13CC;		//LeatherTunic
		1:
			item := 0x1C06;		//FemaleLeather
		endcase
		CreateAndEquip(me,item,CInt(hidecolor));
	endif

	case (Random(51))
		0:	item := 0x26c3; 	//Repeating Crossbow
		1:	item := 0x27a7; 	//Lajatang
		2:	item := 0x27a9; 	//Daisho
		3:	item := 0x27a6; 	//Tetsubo
		4:	item := 0x27af; 	//Sai
		5:	item := 0x27a5;		//Yumi
		6:	item := 0x26c2; 	//Composite Bow
		7:	item := 0x27a8; 	//Bokuto
		8:	item := 0x27a2; 	//No-Dachi
		9:	item := 0x26ce; 	//Paladin Sword
		10:	item := 0x26c1; 	//Crescent Blade
		11:	item := 0x0df0;		//BlackStaff
		12:	item := 0x13f9;		//GnarledStaff
		13:	item := 0x0e8a;		//Quarterstaff
		14:	item := 0x0F60;		//Longsword
		15:	item := 0x13AF;		//WarAxe
		16:	item := 0xb201;		//Icebow
		17:	item := 0x13B2;		//Bow
		18:	item := 0x6050;		//firebow
		19:	item := 0x0f4f;		//Crossbow
		20:	item := 0x13fd;		//HeavyCrossbow
		21:	item := 0x0f49;		//Axe
		22:	item := 0x0f47;		//BattleAxe
		23:	item := 0x0f4b;		//DoubleAxe
		24:	item := 0x0f45;		//ExecutionersAxe
		25:	item := 0x13fa;		//LargeBattleAxe
		26:	item := 0x1442;		//TwoHandedAxe
		27:	item := 0x143c;		//HammerPick
		28:	item := 0x0f5c;		//Mace
		29:	item := 0x143a;		//Maul
		30:	item := 0x1438;		//WarHammer
		31:	item := 0x1406;		//WarMace
		32:	item := 0x0f4e;		//Bardiche
		33:	item := 0x143e;		//Halberd
		34:	item := 0x1402;		//ShortSpear
		35:	item := 0x0f63;		//Spear
		36:	item := 0x1404;		//WarFork
		37:	item := 0x0f5e;		//BroadSword
		38:	item := 0x1440;		//Cutlass
		39:	item := 0x0f51;		//Dagger
		40:	item := 0x13fe;		//Katana
		41:	item := 0x1401;		//Kryss
		42:	item := 0x13b5;		//Scimitar
		43:	item := 0x13b9;		//VikingSword
		44:	item := 0x0f43;		//Hatchet
		45:	item := 0x0e85;		//Pickaxe
		46:	item := 0x13f6;		//ButcherKnife
