// Synopsis: Print the X coordinate of a targeted object to console
use uo;

program  z(who, howfar)

var what := target(who, TGTOPT_NOCHECK_LOS);

if (!what)
        return;
endif
var tdist;

if (howfar == "")
        tdist := 1;
else
        tdist := cint(howfar);
endif


moveobjecttolocation(what, what.x + tdist, what.y, what.z, what.realm);

endprogram
